# Ham Radio Logbook - Environment Configuration Template
# Copy this file to .env and fill in real values before running docker-compose.

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_DB=hamradio_logbook
POSTGRES_USER=hamradio
# Use a strong password - never leave this as the default
POSTGRES_PASSWORD=changeme

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate a secure key: openssl rand -base64 64
JWT_SECRET=replace-with-output-of-openssl-rand-base64-64
JWT_EXPIRATION_MS=86400000

# =============================================================================
# ADMIN USER (auto-created on first startup if set)
# =============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# =============================================================================
# HIBERNATE DDL
# "update" automatically creates/updates schema on startup (recommended)
# =============================================================================
DDL_AUTO=update

# =============================================================================
# QRZ API (optional - for callsign lookups)
# =============================================================================
QRZ_USERNAME=
QRZ_PASSWORD=
