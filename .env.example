# Ham Radio Logbook - Environment Configuration Template
# Copy this to backend/.env and customize for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLite (recommended for local development and field deployment)
SPRING_DATASOURCE_URL=jdbc:sqlite:logbook.db
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.community.dialect.SQLiteDialect

# PostgreSQL (recommended for production multi-user setup)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hamradio_logbook
# SPRING_DATASOURCE_USERNAME=hamradio
# SPRING_DATASOURCE_PASSWORD=changeme
# SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate a secure key: openssl rand -base64 64
JWT_SECRET=YourSecureSecretKeyHere-ChangeThisInProduction-MustBe256BitsMinimum
JWT_EXPIRATION_MS=86400000

# =============================================================================
# ADMIN USER (Auto-created on first startup)
# =============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_EMAIL=admin@hamradio.local

# =============================================================================
# QRZ API (Optional - for callsign lookups)
# =============================================================================
# Sign up at https://www.qrz.com/
QRZ_USERNAME=your_qrz_username
QRZ_PASSWORD=your_qrz_password

# =============================================================================
# DOCKER COMPOSE VARIABLES
# =============================================================================
# PostgreSQL Configuration (for docker-compose.yml)
POSTGRES_DB=hamradio_logbook
POSTGRES_USER=hamradio
POSTGRES_PASSWORD=changeme
