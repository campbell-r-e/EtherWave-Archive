# Rig Control Service — Environment Configuration
# Copy this file to .env and edit for your setup.
# docker compose --env-file .env up

# Port the rig service HTTP/WebSocket server listens on (default: 8081)
RIG_SERVICE_PORT=8081

# ---------------------------------------------------------
# Hamlib rigctld connection
# The rig service connects to a running rigctld process.
# Start rigctld separately: rigctld -m <model_num> -r /dev/ttyUSB0
# ---------------------------------------------------------

# Hostname or IP where rigctld is running
RIGCTLD_HOST=localhost

# TCP port rigctld is listening on (default: 4532)
RIGCTLD_PORT=4532

# Socket read timeout in milliseconds (default: 1000)
RIGCTLD_TIMEOUT=1000

# ---------------------------------------------------------
# PTT Safety Timeout
# Forces PTT off if a client holds it longer than this many seconds.
# Set to 0 to disable (not recommended for unattended operation).
# ---------------------------------------------------------
PTT_SAFETY_TIMEOUT_SECONDS=120

# ---------------------------------------------------------
# WebSocket API Key Authentication
# Comma-separated list of allowed API keys.
# Clients must send the key in the X-Api-Key header or ?apiKey= query param.
# Leave empty to allow all connections (default, backward compatible).
# ---------------------------------------------------------
RIG_API_KEYS=

# Example with two keys:
# RIG_API_KEYS=change-me-key-1,change-me-key-2

# ---------------------------------------------------------
# Cloud Relay (remote station mode)
# When set, the rig service opens an outbound connection to the
# EtherWave Archive backend gateway, allowing it to be controlled
# remotely over the internet without opening inbound ports.
# Leave all three blank for local-only operation (default).
# ---------------------------------------------------------

# Full WSS URL of the backend station gateway endpoint
# Example: wss://my-logbook.example.com/ws/station-gateway
CLOUD_RELAY_GATEWAY_URL=

# Station ID in the logbook database that this rig service represents
CLOUD_RELAY_STATION_ID=

# Plaintext API key that matches the BCrypt hash stored on the Station record
CLOUD_RELAY_API_KEY=

# ---------------------------------------------------------
# Logging
# Valid levels: TRACE, DEBUG, INFO, WARN, ERROR
# ---------------------------------------------------------
LOG_LEVEL=INFO
