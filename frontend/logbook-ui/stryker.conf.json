{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Stryker Mutation Testing Configuration for Angular",
  "packageManager": "npm",
  "reporters": [
    "html",
    "clear-text",
    "progress",
    "dashboard"
  ],
  "testRunner": "karma",
  "karma": {
    "configFile": "karma.conf.js",
    "projectType": "angular-cli",
    "config": {
      "browsers": ["ChromeHeadless"]
    }
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/test.ts",
    "!src/**/*.module.ts",
    "!src/environments/**",
    "!src/main.ts",
    "!src/polyfills.ts"
  ],
  "thresholds": {
    "high": 85,
    "low": 75,
    "break": 70
  },
  "mutator": {
    "plugins": [
      "@stryker-mutator/*"
    ]
  },
  "timeoutMS": 60000,
  "timeoutFactor": 2,
  "maxConcurrentTestRunners": 2,
  "disableTypeChecks": false,
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "ignorePatterns": [
    "node_modules",
    "dist",
    "coverage",
    "*.spec.ts",
    "test.ts"
  ],
  "dashboard": {
    "project": "hamradio-logbook",
    "version": "main",
    "module": "frontend"
  },
  "htmlReporter": {
    "baseDir": "reports/mutation"
  },
  "clearTextReporter": {
    "allowColor": true,
    "logTests": false
  }
}
