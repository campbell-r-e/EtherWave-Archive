    // ==================== SECURITY HEADERS TESTS ====================

    @Test
    @WithMockUser(username = "testuser")
    @DisplayName("GET /api/qsos - Includes Security Headers")
    void getQsos_includesSecurityHeaders() throws Exception {
        mockMvc.perform(get("/api/qsos"))
                .andExpect(status().isOk())
                .andExpect(header().exists("X-Content-Type-Options"))
                .andExpect(header().exists("X-Frame-Options"))
                .andExpect(header().exists("X-XSS-Protection"));
    }

    // ==================== MULTIPLE AUTHENTICATION METHODS TESTS ====================

    @Test
    @DisplayName("POST /api/auth/login - Valid Credentials - Returns Token")
    void postAuthLogin_validCredentials_returnsToken() throws Exception {
        mockMvc.perform(post("/api/auth/login")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content("{\"username\":\"testuser\",\"password\":\"password\"}"))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.token").exists());
    }

    @Test
    @DisplayName("POST /api/auth/login - Invalid Credentials - Returns Error")
    void postAuthLogin_invalidCredentials_returnsError() throws Exception {
        mockMvc.perform(post("/api/auth/login")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content("{\"username\":\"invalid\",\"password\":\"wrong\"}"))
                .andExpect(status().isUnauthorized());
    }
