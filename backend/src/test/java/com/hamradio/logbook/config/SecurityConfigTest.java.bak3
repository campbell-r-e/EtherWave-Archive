    // ==================== CONTEST ENDPOINT TESTS ====================

    @Test
    @WithMockUser(username = "testuser")
    @DisplayName("GET /api/contests - Authenticated User - Allows Access")
    void getContests_authenticatedUser_allowsAccess() throws Exception {
        mockMvc.perform(get("/api/contests"))
                .andExpect(status().isOk());
    }

    @Test
